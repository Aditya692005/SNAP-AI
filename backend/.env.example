# Copy this file to .env and fill in your real values. Never commit .env.

PORT=5000

# Supabase (Postgres + pgvector + Storage)
SUPABASE_URL=https://<project-ref>.supabase.co

# The ANON key. Fine for this app's tables, which have RLS explicitly disabled.
SUPABASE_KEY=eyJ...

# The SERVICE_ROLE key (Project Settings -> API -> service_role). Used ONLY for the
# private `documents` Storage bucket, which holds the original uploaded files.
#
# This is separate from SUPABASE_KEY on purpose. storage.objects has RLS enabled and,
# unlike the app's own tables, it cannot be disabled on hosted Supabase — so the anon
# key genuinely cannot read or write the bucket. Granting anon a storage policy instead
# would make the bucket world-accessible, because the anon key is designed to be public.
#
# Server-side only. Never expose this to the frontend.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Bucket holding original document bytes (created by sql/add-document-storage.sql).
SUPABASE_BUCKET=documents

# JWT
JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Python RAG service (chunking, embeddings, chat, charts)
RAG_SERVICE_URL=http://localhost:8000

# Allow the Vite dev server (and your deployed frontend URL) to call this API
CORS_ORIGIN=http://localhost:5173

# Used to build the links in verification / invite / reset emails
FRONTEND_URL=http://localhost:5173

# Gmail account used to send those emails (an App Password, not the login password)
EMAIL_USER=you@gmail.com
EMAIL_PASSWORD=your_16_char_app_password
